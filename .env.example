# floorgen environment variables
# Copy to .env for local reference, then export the variables or run commands
# through your shell/env-file loader. The Python package reads process env.

# --- Data ---
# Official Kaggle split CSVs. Use these for submission preprocessing so test
# membership and original plan/unit/floor ids are preserved.
MSD_TRAIN_CSV_PATH=
MSD_TEST_CSV_PATH=

# Alternative: point at the extracted Kaggle directory. The preprocessing CLI
# will autodetect one CSV with "train" and one with "test" in the filename.
MSD_KAGGLE_DIR=

# Development fallback: one unsplit Modified Swiss Dwellings CSV.
# Required only for single-CSV preprocessing; not needed for generation or demo.
MSD_CSV_PATH=

# Output directory for preprocessed per-unit records (default: data/processed)
FLOORGEN_PROCESSED=data/processed

# Output directory for preprocessing reports (default: reports)
FLOORGEN_REPORTS=reports

# --- Trained generator runtime ---
# Default local judged model. Set FLOORGEN_MODEL=mlp to run the trained legacy
# MLP checkpoint on the same local device resolver.
FLOORGEN_MODEL=amd-transformer

# Optional override. Accepts aliases (`amd-transformer`, `mlp`) or a checkpoint path.
FLOORGEN_CHECKPOINT=
FLOORGEN_DEVICE=auto
FLOORGEN_SAMPLE_STEPS=16
FLOORGEN_PRESENCE_THRESHOLD=0.5
FLOORGEN_GENERATION_MODE=ranked
FLOORGEN_CANDIDATE_BUDGET=16

# --- Remote GPU (AMD box, for training) ---
AMD_IP=
AMD_SSH_USER=root
AMD_ROOT_PASSWORD=
AMD_JUPYTER_URL=
AMD_JUPYTER_TOKEN=
