# floorgen environment variables
# Copy to .env and fill in values as needed.

# --- Data ---
# Path to the Modified Swiss Dwellings CSV (~370k rows, from Kaggle).
# Required only for preprocessing; not needed for generation or demo.
MSD_CSV_PATH=

# Output directory for preprocessed per-unit records (default: data/processed)
FLOORGEN_PROCESSED=data/processed

# Output directory for preprocessing reports (default: reports)
FLOORGEN_REPORTS=reports

# --- Remote GPU (AMD box, for training) ---
AMD_IP=
AMD_SSH_USER=root
AMD_ROOT_PASSWORD=
AMD_JUPYTER_URL=
AMD_JUPYTER_TOKEN=
